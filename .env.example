# Copy this file to .env for Docker Compose.
# For manual host-based runs, replace service hostnames with localhost values.

# Spring profile
SPRING_PROFILES_ACTIVE=local

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=5432
POSTGRES_DB=microservice
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/microservice
HIBERNATE_DDL_AUTO=validate
USER_SERVICE_DB_SCHEMA=user_service
JOB_SERVICE_DB_SCHEMA=job_service
NOTIFICATION_SERVICE_DB_SCHEMA=notification_service
FILE_STORAGE_DB_SCHEMA=file_storage

# Service discovery and config
EUREKA_URI=http://eureka-server:8761/eureka
CONFIG_SERVER_URI=http://config-server:8888
CONFIG_SERVER_PROFILE=native
CONFIG_NATIVE_SEARCH_LOCATIONS=file:/config
CONFIG_SERVER_HOST_PORT=8888
EUREKA_HOST_PORT=8761

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9093
KAFKA_HOST_PORT=9092
KAFKA_UI_HOST_PORT=9090
NOTIFICATION_TOPIC=notificationTopic
NOTIFICATION_CONSUMER_GROUP=notification

# Security
# Local-only example secret. Generate a strong Base64-encoded HS256 secret before running outside local development.
JWT_SECRET=MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=
JWT_EXPIRATION_MS=3600000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
ADMIN_BOOTSTRAP_ENABLED=false
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=

# Gateway
GATEWAY_DISCOVERY_LOCATOR_ENABLED=true
GATEWAY_HOST_PORT=8080

# Stable internal service ports used by Docker Compose
CONFIG_SERVER_PORT=8888
EUREKA_SERVER_PORT=8761
GATEWAY_PORT=8080
AUTH_SERVICE_PORT=8081
USER_SERVICE_PORT=8082
JOB_SERVICE_PORT=8083
NOTIFICATION_SERVICE_PORT=8084
FILE_STORAGE_PORT=8085

# File storage
FILE_STORAGE_PATH=/data/uploads
MAX_FILE_SIZE=5MB
MAX_REQUEST_SIZE=5MB

# JVM defaults for containers
JAVA_TOOL_OPTIONS=-XX:MaxRAMPercentage=75.0 -XX:+ExitOnOutOfMemoryError

# Actuator and basic observability
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,metrics
MANAGEMENT_HEALTH_SHOW_DETAILS=when_authorized
